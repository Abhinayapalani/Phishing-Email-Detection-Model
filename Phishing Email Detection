import re
from sklearn.model_selection import train_test_split
from sklearn.feature_extraction.text import TfidfVectorizer
from sklearn.ensemble import ExtraTreesClassifier
from sklearn.metrics import accuracy_score, confusion_matrix, classification_report

# Suspicious keywords
keywords = ["verify","login","password","urgent","bank",
            "account","winner","reward","click","free","payment","update"]

# Feature extraction
def extract_features(text):
    text = text.lower()
    return [
        len(re.findall(r'https?://|www\.', text)),  # URLs
        sum(c.isdigit() for c in text),             # Digits
        text.count("!"),                            # Exclamation marks
        sum(word in text for word in keywords)      # Keyword count
    ]

# Create extra features
extra = data["text"].apply(extract_features)

import pandas as pd
extra = pd.DataFrame(extra.tolist(),
                     columns=["URLs","Digits","Exclamation","Keywords"])

# TF-IDF
vectorizer = TfidfVectorizer(stop_words="english")
tfidf = vectorizer.fit_transform(data["text"])

tfidf_df = pd.DataFrame(
    tfidf.toarray(),
    columns=vectorizer.get_feature_names_out()
)

# Combine features
X = pd.concat([tfidf_df, extra], axis=1)
y = data["label"]

# Train/Test split
X_train, X_test, y_train, y_test = train_test_split(
    X, y, test_size=0.25, random_state=42
)

# Train model
model = ExtraTreesClassifier(random_state=42)
model.fit(X_train, y_train)

# Prediction
pred = model.predict(X_test)

print("Accuracy:", accuracy_score(y_test, pred))
print("\nClassification Report")
print(classification_report(y_test, pred))
print("\nConfusion Matrix")
print(confusion_matrix(y_test, pred))

