    [extract_features(email)],
    columns=["URLs","Digits","Exclamation","Keywords"]
)

tfidf_email = pd.DataFrame(
    vectorizer.transform([email]).toarray(),
    columns=tfidf_df.columns
)

test = pd.concat([tfidf_email, extra_feature], axis=1)

result = model.predict(test)[0]

print("\nPrediction:", result)

